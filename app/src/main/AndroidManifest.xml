<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pda">
        <activity
            android:name=".QuerySellGetMoneyActivity"
            android:exported="false"
            android:label="@string/menu_query_sell_get_money"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".QueryBillActivity"
            android:exported="false"
            android:label="@string/query_bill_title"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".QueryOrderActivity"
            android:exported="false"
            android:label="@string/menu_query_order"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".QuerySellDetailActivity"
            android:exported="false"
            android:label="@string/menu_sell_detail"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".SaleAnalysisActivity"
            android:exported="false"
            android:label="@string/sale_analysis_title"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".OnlineRefundActivity"
            android:exported="false"
            android:label="@string/online_refund_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".ScanPayActivity"
            android:exported="false"
            android:label="@string/scan_pay_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".SelectGoodsActivity"
            android:exported="false"
            android:label="@string/sell_normal_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".SellActivity"
            android:exported="false"
            android:label="@string/sell_normal_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".DownloadActivity"
            android:exported="false"
            android:label="@string/download_common_data_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".MenuActivity"
            android:exported="false"
            android:label="@string/menu_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".SystemSettingActivity"
            android:exported="false"
            android:label="@string/system_setting_title"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".SettingActivity"
            android:exported="false"
            android:label="@string/title_setting"
            android:theme="@style/Theme.Pda" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Pda">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="default_text">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="button_long">
        <item name="android:textSize">@dimen/content_text_14</item>
        <item name="android:textColor">@color/button_long_text</item>
        <item name="android:background">@drawable/button_long_frame</item>
    </style>

    <style name="edittext_1" parent="@style/default_text">
        <item name="android:textSize">@dimen/content_text_14</item>
        <item name="android:background">@drawable/color_text</item>
    </style>

    <style name="explain_text_1">
        <item name="android:textSize">@dimen/add_content_text_12</item>
        <item name="android:textColor">@color/explain_text_color_1</item>
    </style>

    <style name="explain_text_2">
        <item name="android:textSize">@dimen/add_content_text_12</item>
        <item name="android:textColor">@color/explain_text_color_2</item>
    </style>

    <style name="text_ui">
        <item name="android:textSize">@dimen/content_text_14</item>
        <item name="android:textColor">@color/ui_text_color</item>
    </style>

    <style name="title_small_text">
        <item name="android:textSize">@dimen/title_text_14</item>
        <item name="android:textColor">@color/title_small_text_color</item>
    </style>

    <style name="title_text">
        <item name="android:textSize">@dimen/title_text_16</item>
        <item name="android:textColor">@color/title_fence_text_white</item>
    </style>

    <style name="title_text_button">
        <item name="android:textSize">@dimen/title_text_12</item>
        <item name="android:textColor">@color/title_fence_text_white</item>
        <item name="android:background">@drawable/bg_title_btn</item>
    </style>

    <style name="PopupWindowAnimation" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@anim/in_bottomtotop</item>
        <item name="android:windowExitAnimation">@anim/out_toptobottom</item>
    </style>

    <style name="ProgressAnim" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@anim/progress_in</item>
        <item name="android:windowExitAnimation">@anim/progress_out</item>
    </style>
</resources>

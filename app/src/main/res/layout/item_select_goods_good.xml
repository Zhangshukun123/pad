<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/isgg_tv_type"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@color/lightgray"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_3"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_3"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        android:textStyle="bold"
        android:visibility="gone" />

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/isgg_cl_content"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_4"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginEnd="@dimen/dp_3"
        android:background="@drawable/bg_green_border_round"
        android:padding="@dimen/dp_4">

        <TextView
            android:id="@+id/isgg_tv_name"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_6"
            android:maxLines="2"
            android:textColor="@color/black"
            android:textSize="@dimen/text_14"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/isgg_iv_reduce"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/isgg_tv_price"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_2"
            android:textColor="@color/sgf_goods_item_price_text"
            android:textSize="@dimen/text_14"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/isgg_iv_reduce"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/isgg_tv_name" />

        <TextView
            android:id="@+id/isgg_tv_stock"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_1"
            android:textColor="@color/explain_text_color_2"
            android:textSize="@dimen/text_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/isgg_iv_reduce"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/isgg_tv_price" />

        <ImageView
            android:id="@+id/isgg_iv_add"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:contentDescription="@string/select_goods_action_add"
            android:padding="@dimen/dp_2"
            android:scaleType="fitXY"
            android:src="@mipmap/ic_add"
            app:layout_constraintBottom_toBottomOf="@id/isgg_tv_stock"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/isgg_tv_price" />

        <TextView
            android:id="@+id/isgg_tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_4"
            android:gravity="center"
            android:minWidth="@dimen/dp_24"
            android:text="0"
            android:textColor="@color/black"
            android:textSize="@dimen/text_14"
            app:layout_constraintBottom_toBottomOf="@id/isgg_iv_add"
            app:layout_constraintEnd_toStartOf="@id/isgg_iv_add"
            app:layout_constraintTop_toTopOf="@id/isgg_iv_add" />

        <ImageView
            android:id="@+id/isgg_iv_reduce"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:contentDescription="@string/select_goods_action_reduce"
            android:padding="@dimen/dp_2"
            android:scaleType="fitXY"
            android:src="@mipmap/ic_reduce"
            app:layout_constraintBottom_toBottomOf="@id/isgg_iv_add"
            app:layout_constraintEnd_toStartOf="@id/isgg_tv_count"
            app:layout_constraintTop_toTopOf="@id/isgg_iv_add" />

        <ImageView
            android:id="@+id/isgg_iv_stock_status"
            android:layout_width="@dimen/dp_50"
            android:layout_height="@dimen/dp_50"
            android:layout_marginTop="@dimen/dp_2"
            android:layout_marginEnd="@dimen/dp_8"
            android:contentDescription="@string/select_goods_stock_status"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>

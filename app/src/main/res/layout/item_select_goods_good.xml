<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/dp_5"
    android:layout_marginTop="@dimen/dp_5"
    android:layout_marginEnd="@dimen/dp_3"
    android:background="@drawable/bg_green_border_round"
    android:padding="@dimen/dp_5">

    <TextView
        android:id="@+id/isgg_tv_name"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_10"
        android:maxLines="2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_16"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/isgg_iv_reduce"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/isgg_tv_price"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:textColor="@color/sgf_goods_item_price_text"
        android:textSize="@dimen/text_16"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/isgg_iv_reduce"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/isgg_tv_name" />

    <TextView
        android:id="@+id/isgg_tv_stock"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_4"
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/isgg_iv_reduce"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/isgg_tv_price" />

    <ImageView
        android:id="@+id/isgg_iv_add"
        android:layout_width="@dimen/dp_35"
        android:layout_height="@dimen/dp_35"
        android:contentDescription="@string/select_goods_action_add"
        android:padding="@dimen/dp_2"
        android:scaleType="fitXY"
        android:src="@mipmap/ic_add"
        app:layout_constraintBottom_toBottomOf="@id/isgg_tv_stock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/isgg_tv_price" />

    <TextView
        android:id="@+id/isgg_tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_5"
        android:gravity="center"
        android:minWidth="@dimen/dp_30"
        android:text="0"
        android:textColor="@color/black"
        android:textSize="@dimen/text_16"
        app:layout_constraintBottom_toBottomOf="@id/isgg_iv_add"
        app:layout_constraintEnd_toStartOf="@id/isgg_iv_add"
        app:layout_constraintTop_toTopOf="@id/isgg_iv_add" />

    <ImageView
        android:id="@+id/isgg_iv_reduce"
        android:layout_width="@dimen/dp_35"
        android:layout_height="@dimen/dp_35"
        android:contentDescription="@string/select_goods_action_reduce"
        android:padding="@dimen/dp_2"
        android:scaleType="fitXY"
        android:src="@mipmap/ic_reduce"
        app:layout_constraintBottom_toBottomOf="@id/isgg_iv_add"
        app:layout_constraintEnd_toStartOf="@id/isgg_tv_count"
        app:layout_constraintTop_toTopOf="@id/isgg_iv_add" />

</androidx.constraintlayout.widget.ConstraintLayout>

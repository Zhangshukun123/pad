<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent">

    <com.journeyapps.barcodescanner.BarcodeView
        android:id="@+id/asp_barcode_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dp_48"
            android:background="#B3000000">

            <ImageView
                android:id="@+id/asp_iv_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="fill_parent"
                android:padding="@dimen/dp_10"
                android:src="@drawable/ic_scan_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/scan_pay_title"
                android:textColor="@color/white"
                android:textSize="@dimen/text_18"
                android:textStyle="bold" />
        </RelativeLayout>

        <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <View
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:background="@drawable/scan_mask" />

            <FrameLayout
                android:id="@+id/asp_fl_scan_frame"
                android:layout_width="@dimen/dp_200"
                android:layout_height="@dimen/dp_200"
                android:layout_gravity="center"
                android:clipChildren="true"
                android:clipToPadding="true">

                <ImageView
                    android:id="@+id/asp_iv_scan_line"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/dp_6"
                    android:layout_marginStart="@dimen/dp_5"
                    android:layout_marginEnd="@dimen/dp_5"
                    android:layout_marginTop="@dimen/dp_5"
                    android:scaleType="fitXY"
                    android:src="@drawable/scan_ray" />

                <ImageView
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/scan_capture_frame" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dp_100"
            android:background="#B3000000"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/asp_ll_flash"
                android:layout_width="0dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/asp_iv_flash"
                    android:layout_width="@dimen/dp_36"
                    android:layout_height="@dimen/dp_36"
                    android:alpha="0.75"
                    android:src="@drawable/scan_light" />

                <TextView
                    android:id="@+id/asp_tv_flash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_6"
                    android:text="@string/scan_pay_open_flash"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_14" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/asp_ll_album"
                android:layout_width="0dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/dp_36"
                    android:layout_height="@dimen/dp_36"
                    android:src="@drawable/ic_scan_album" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_6"
                    android:text="@string/scan_pay_album"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_14" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

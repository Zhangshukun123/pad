<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:background="@drawable/bg_white_solid_green_border_round"
    android:padding="@dimen/dp_5"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 水印：商品总数，右下角大号半透明数字 -->
    <TextView
        android:id="@+id/tv_count"
        android:textSize="@dimen/text_60"
        android:textColor="@color/black_24"
        android:alpha="0.08"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_5"
        app:layout_constraintBottom_toTopOf="@+id/i_aqo_ll_table_head"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- 订单号 -->
    <TextView
        android:id="@+id/tv_order_code"
        android:textSize="@dimen/text_16"
        android:textColor="#ff0187eb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/text_ui" />

    <!-- 分割线 -->
    <View
        android:id="@+id/aqo_divider"
        android:background="@color/divider_color_gray"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_1"
        android:layout_marginTop="@dimen/dp_2"
        app:layout_constraintTop_toBottomOf="@+id/tv_order_code" />

    <!-- 时间 -->
    <TextView
        android:id="@+id/tv_order_date_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="时　　间："
        app:layout_constraintBottom_toBottomOf="@+id/tv_order_date"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/tv_order_date"
        app:layout_constraintTop_toTopOf="@+id/tv_order_date"
        style="@style/text_ui_hint" />

    <TextView
        android:id="@+id/tv_order_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        app:layout_constraintLeft_toRightOf="@+id/tv_order_date_hint"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aqo_divider"
        style="@style/text_ui" />

    <!-- 金额 -->
    <TextView
        android:id="@+id/tv_order_amount_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="金　　额："
        app:layout_constraintBottom_toBottomOf="@+id/tv_order_amount"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/tv_order_amount"
        app:layout_constraintTop_toTopOf="@+id/tv_order_amount"
        style="@style/text_ui_hint" />

    <TextView
        android:id="@+id/tv_order_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toRightOf="@+id/tv_order_amount_hint"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_order_date"
        style="@style/text_ui" />

    <!-- 支付方式 + 网络订餐车次（同一行） -->
    <TextView
        android:id="@+id/tv_order_pay_channel_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="支付方式："
        app:layout_constraintBottom_toBottomOf="@+id/tv_order_pay_channel"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/tv_order_pay_channel"
        app:layout_constraintTop_toTopOf="@+id/tv_order_pay_channel"
        style="@style/text_ui_hint" />

    <TextView
        android:id="@+id/tv_order_pay_channel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toRightOf="@+id/tv_order_pay_channel_hint"
        app:layout_constraintRight_toLeftOf="@+id/tv_order_train_name_hint"
        app:layout_constraintTop_toBottomOf="@+id/tv_order_amount"
        style="@style/text_ui" />

    <TextView
        android:id="@+id/tv_order_train_name_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="网络订餐车次："
        app:layout_constraintBottom_toBottomOf="@+id/tv_order_train_name"
        app:layout_constraintLeft_toRightOf="@+id/tv_order_pay_channel"
        app:layout_constraintRight_toLeftOf="@+id/tv_order_train_name"
        app:layout_constraintTop_toTopOf="@+id/tv_order_train_name"
        style="@style/text_ui_hint" />

    <TextView
        android:id="@+id/tv_order_train_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toRightOf="@+id/tv_order_train_name_hint"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_order_amount"
        style="@style/text_ui" />

    <!-- 12306 专属信息（默认 gone） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/aqo_cl_12306"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tv_order_pay_channel">

        <TextView
            android:id="@+id/aqo_tv_seat_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="座位信息："
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/aqo_tv_seat"
            app:layout_constraintTop_toTopOf="@+id/aqo_tv_seat"
            style="@style/text_ui_hint" />

        <TextView
            android:id="@+id/aqo_tv_seat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toRightOf="@+id/aqo_tv_seat_hint"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/text_ui" />

        <TextView
            android:id="@+id/aqo_tv_contacts_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="联系信息："
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/aqo_tv_contacts"
            app:layout_constraintTop_toTopOf="@+id/aqo_tv_contacts"
            style="@style/text_ui_hint" />

        <TextView
            android:id="@+id/aqo_tv_contacts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toRightOf="@+id/aqo_tv_contacts_hint"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/aqo_tv_seat"
            style="@style/text_ui" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 商品明细表头 -->
    <LinearLayout
        android:id="@+id/i_aqo_ll_table_head"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/table_grid_igh"
        android:layout_marginTop="@dimen/dp_3"
        app:layout_constraintTop_toBottomOf="@+id/aqo_cl_12306">

        <View
            android:background="@color/colorPrimary"
            android:layout_width="@dimen/dp_1"
            android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="商品编码"
            android:textColor="@color/white"
            style="@style/table_grid_text_new" />

        <View android:background="@color/divider_color_gray" android:layout_width="@dimen/dp_1" android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="5"
            android:text="商品名称"
            android:textColor="@color/white"
            style="@style/table_grid_text_new" />

        <View android:background="@color/divider_color_gray" android:layout_width="@dimen/dp_1" android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="单价"
            android:textColor="@color/white"
            style="@style/table_grid_text_new" />

        <View android:background="@color/divider_color_gray" android:layout_width="@dimen/dp_1" android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="数量"
            android:textColor="@color/white"
            style="@style/table_grid_text_new" />

        <View android:background="@color/divider_color_gray" android:layout_width="@dimen/dp_1" android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="小计"
            android:textColor="@color/white"
            style="@style/table_grid_text_new" />

        <View
            android:background="@color/colorPrimary"
            android:layout_width="@dimen/dp_1"
            android:layout_height="match_parent" />

    </LinearLayout>

    <!-- 商品明细行容器 -->
    <LinearLayout
        android:id="@+id/i_aqo_ll_table"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/i_aqo_ll_table_head" />

</androidx.constraintlayout.widget.ConstraintLayout>

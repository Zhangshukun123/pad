<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:collapsedTitleGravity="left"
            app:collapsedTitleTextAppearance="@style/ToolBarTitleText"
            app:contentScrim="@color/title_fence_background"
            app:expandedTitleGravity="bottom|center|left"
            app:expandedTitleMarginBottom="@dimen/dp_10"
            app:expandedTitleTextAppearance="@style/ToolBarTitleText"
            app:layout_scrollFlags="exitUntilCollapsed|scroll"
            app:titleEnabled="false">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tool_bar"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:contentInsetStart="0dp"
                app:contentInsetEnd="0dp"
                app:contentInsetLeft="0dp"
                app:contentInsetRight="0dp"
                app:layout_collapseMode="pin"
                app:title="@null">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_40"
                        app:layout_constraintTop_toTopOf="parent"
                        layout="@layout/app_title" />

                    <include
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/cl_title"
                        layout="@layout/app_user_info" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.appcompat.widget.Toolbar>

            <!-- 筛选区域 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_55"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.99">

                <!-- 支付方式 -->
                <TextView
                    android:id="@+id/tv_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_order_filter_pay_type"
                    app:layout_constraintBottom_toBottomOf="@+id/aqo_sp_pay_type"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@+id/aqo_sp_pay_type"
                    app:layout_constraintTop_toTopOf="@+id/aqo_sp_pay_type"
                    style="@style/default_text" />

                <Spinner
                    android:id="@+id/aqo_sp_pay_type"
                    android:background="@drawable/bg_spinner_green_border"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/spinner_high"
                    android:layout_marginTop="@dimen/dp_5"
                    app:layout_constraintLeft_toRightOf="@+id/tv_3"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- 订单类型 -->
                <TextView
                    android:id="@+id/tv_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_order_filter_order_type"
                    app:layout_constraintBottom_toBottomOf="@+id/aqo_sp_order_type"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@+id/aqo_sp_order_type"
                    app:layout_constraintTop_toTopOf="@+id/aqo_sp_order_type"
                    style="@style/default_text" />

                <Spinner
                    android:id="@+id/aqo_sp_order_type"
                    android:background="@drawable/bg_spinner_green_border"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/spinner_high"
                    android:layout_marginTop="@dimen/dp_5"
                    app:layout_constraintLeft_toRightOf="@+id/tv_4"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/aqo_sp_pay_type" />

                <!-- 订餐车次 -->
                <TextView
                    android:id="@+id/tv_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_order_filter_train"
                    app:layout_constraintBottom_toBottomOf="@+id/aqo_et_train_name"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@+id/aqo_et_train_name"
                    app:layout_constraintTop_toTopOf="@+id/aqo_et_train_name"
                    style="@style/default_text" />

                <com.ayma.base.widget.ClearEditText
                    android:id="@+id/aqo_et_train_name"
                    android:background="@drawable/bg_spinner_green_border"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/spinner_high"
                    android:layout_marginTop="@dimen/dp_5"
                    android:paddingLeft="@dimen/dp_5"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:maxLines="1"
                    android:singleLine="true"
                    app:layout_constraintLeft_toRightOf="@+id/tv_5"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/aqo_sp_order_type" />

                <!-- 日期范围选择 -->
                <LinearLayout
                    android:id="@+id/aqo_ll_filter_container"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_5"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/aqo_et_train_name">

                    <TextView
                        android:id="@+id/aqo_tv_start_time"
                        android:textSize="@dimen/text_16"
                        android:textColor="@color/black_24"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/aqo_tv_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" - "
                        android:layout_marginStart="@dimen/dp_5" />

                    <TextView
                        android:id="@+id/aqo_tv_end_time"
                        android:textSize="@dimen/text_16"
                        android:textColor="@color/black_24"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5" />

                </LinearLayout>

                <!-- 最新/最早 排序 -->
                <RadioGroup
                    android:id="@+id/aqo_rg_date_sort"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_5"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/aqo_ll_filter_container">

                    <RadioButton
                        android:id="@+id/aqo_rb_newest"
                        android:textColor="@color/black_24"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/query_order_sort_newest" />

                    <RadioButton
                        android:id="@+id/aqo_rb_early"
                        android:textColor="@color/black_24"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/query_order_sort_early" />

                </RadioGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/aqo_rlv_data"
        android:visibility="visible"
        android:layoutAnimation="@anim/layout_animation_fall_down"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <TextView
        android:textSize="20sp"
        android:gravity="center"
        android:id="@+id/aqo_tv_no_data"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_100"
        android:text="@string/query_order_no_data"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

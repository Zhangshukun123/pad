<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/aor_ll_query_input"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_40"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_5"
        android:background="@drawable/bg_online_pay_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/dp_2"
        app:layout_constraintEnd_toStartOf="@id/aor_tv_query"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.ayma.base.widget.ClearEditText
            android:id="@+id/aor_et_transaction_code"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_35"
            android:layout_weight="1"
            android:background="@color/white"
            android:hint="@string/online_refund_input_hint"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:paddingStart="@dimen/dp_5"
            android:singleLine="true"
            android:textSize="@dimen/text_14" />

        <ImageView
            android:id="@+id/aor_iv_scan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/dp_5"
            android:src="@mipmap/scan" />
    </LinearLayout>

    <TextView
        android:id="@+id/aor_tv_query"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginEnd="@dimen/dp_5"
        android:background="@drawable/button_long_frame"
        android:gravity="center"
        android:padding="@dimen/dp_5"
        android:text="@string/online_refund_action_query"
        android:textColor="@color/white"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_ll_query_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_ll_query_input" />

    <View
        android:id="@+id/aor_v_green_line"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dp_1"
        android:layout_marginTop="@dimen/dp_5"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toBottomOf="@id/aor_ll_query_input" />

    <TextView
        android:id="@+id/aor_tv_order_no_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_10"
        android:text="|订单号："
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_tv_order_no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_tv_order_no" />

    <TextView
        android:id="@+id/aor_tv_order_no"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_15"
        android:layout_marginEnd="@dimen/dp_10"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_2"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/aor_tv_order_no_hint"
        app:layout_constraintTop_toBottomOf="@id/aor_v_green_line" />

    <TextView
        android:id="@+id/aor_tv_order_date_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_10"
        android:text="|订单日期："
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_tv_order_date"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_tv_order_date" />

    <TextView
        android:id="@+id/aor_tv_order_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginEnd="@dimen/dp_10"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_2"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/aor_tv_order_date_hint"
        app:layout_constraintTop_toBottomOf="@id/aor_tv_order_no" />

    <TextView
        android:id="@+id/aor_tv_channel_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_10"
        android:text="|交易渠道："
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_tv_channel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_tv_channel" />

    <TextView
        android:id="@+id/aor_tv_channel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginEnd="@dimen/dp_10"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_2"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/aor_tv_channel_hint"
        app:layout_constraintTop_toBottomOf="@id/aor_tv_order_date" />

    <TextView
        android:id="@+id/aor_tv_train_name_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_10"
        android:text="|车次名称："
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_tv_train_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_tv_train_name" />

    <TextView
        android:id="@+id/aor_tv_train_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginEnd="@dimen/dp_10"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_2"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/aor_tv_train_name_hint"
        app:layout_constraintTop_toBottomOf="@id/aor_tv_channel" />

    <TextView
        android:id="@+id/aor_tv_out_date_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_10"
        android:text="|出乘日期："
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_tv_out_date"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_tv_out_date" />

    <TextView
        android:id="@+id/aor_tv_out_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginEnd="@dimen/dp_10"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_2"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/aor_tv_out_date_hint"
        app:layout_constraintTop_toBottomOf="@id/aor_tv_train_name" />

    <TextView
        android:id="@+id/aor_tv_total_price_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_10"
        android:text="|支付金额："
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_14"
        app:layout_constraintBottom_toBottomOf="@id/aor_tv_total_price"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aor_tv_total_price" />

    <TextView
        android:id="@+id/aor_tv_total_price"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginEnd="@dimen/dp_10"
        android:paddingStart="@dimen/dp_5"
        android:paddingTop="@dimen/dp_2"
        android:paddingEnd="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_2"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/aor_tv_total_price_hint"
        app:layout_constraintTop_toBottomOf="@id/aor_tv_out_date" />

</androidx.constraintlayout.widget.ConstraintLayout>

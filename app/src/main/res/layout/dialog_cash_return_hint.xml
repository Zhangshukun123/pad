<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_white_round"
    android:orientation="vertical"
    android:paddingStart="@dimen/dp_12"
    android:paddingTop="@dimen/dp_12"
    android:paddingEnd="@dimen/dp_12"
    android:paddingBottom="@dimen/dp_10">

    <TextView
        android:id="@+id/dcrh_tv_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="@dimen/dp_2"
        android:text="@string/sell_cash_return_hint_message"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14" />

    <CheckBox
        android:id="@+id/dcrh_cb_skip_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/dp_8"
        android:buttonTint="@color/deep_gray"
        android:checked="false"
        android:text="@string/sell_cash_return_skip_hint"
        android:textColor="@color/black"
        android:textSize="@dimen/text_14" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/dp_10"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dcrh_tv_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dp_12"
            android:paddingTop="@dimen/dp_4"
            android:paddingEnd="@dimen/dp_12"
            android:paddingBottom="@dimen/dp_4"
            android:text="@string/action_cancel"
            android:textColor="@color/colorPrimaryDark"
            android:textSize="@dimen/text_14"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dcrh_tv_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_8"
            android:paddingStart="@dimen/dp_12"
            android:paddingTop="@dimen/dp_4"
            android:paddingEnd="@dimen/dp_12"
            android:paddingBottom="@dimen/dp_4"
            android:text="@string/action_confirm"
            android:textColor="@color/colorPrimaryDark"
            android:textSize="@dimen/text_14"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/bill_table_grid_igh">

    <TextView
        android:id="@+id/iaqbl_tv_goods_code"
        android:visibility="gone"
        android:layout_width="@dimen/dp_80"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:visibility="gone"
        android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_name"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:layout_weight="1.0"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_price"
        android:layout_width="@dimen/dp_50"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_from_stock"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_add"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_transfer_in"
        android:layout_width="@dimen/dp_40"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_transfer_out"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_return"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_scrapped"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_lost"
        android:layout_width="@dimen/dp_40"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_sale_out"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_sale_in"
        android:layout_width="@dimen/dp_39"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

    <View android:background="@color/divider_color_gray"
        android:layout_width="@dimen/dp_1"
        android:layout_height="fill_parent" />

    <TextView
        android:id="@+id/iaqbl_tv_goods_sale_12306"
        android:layout_width="@dimen/dp_40"
        android:layout_height="fill_parent"
        style="@style/table_grid_text_new" />

</LinearLayout>

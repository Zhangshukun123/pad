<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/table_grid_igh"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tv_detail_code"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        style="@style/table_grid_text_new" />

    <View android:layout_width="@dimen/dp_1" android:layout_height="match_parent" android:background="@color/divider_color_gray" />

    <TextView
        android:id="@+id/tv_detail_name"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5"
        style="@style/table_grid_text_new" />

    <View android:layout_width="@dimen/dp_1" android:layout_height="match_parent" android:background="@color/divider_color_gray" />

    <TextView
        android:id="@+id/tv_detail_price"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        style="@style/table_grid_text_new" />

    <View android:layout_width="@dimen/dp_1" android:layout_height="match_parent" android:background="@color/divider_color_gray" />

    <TextView
        android:id="@+id/tv_detail_qty"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        style="@style/table_grid_text_new" />

    <View android:layout_width="@dimen/dp_1" android:layout_height="match_parent" android:background="@color/divider_color_gray" />

    <TextView
        android:id="@+id/tv_detail_subtotal"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        style="@style/table_grid_text_new" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_user"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/explain_text_background">

    <TextView
        android:id="@+id/aui_tv_user_name"
        style="@style/explain_text_3"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_5"
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_12"
        app:layout_constraintBottom_toBottomOf="@id/aui_tv_train_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/aui_tv_train_name" />

    <TextView
        android:id="@+id/aui_tv_train_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <TextView
        android:id="@+id/aui_tv_train_date"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_5"
        android:gravity="right"
        android:textColor="@color/explain_text_color_2"
        android:textSize="@dimen/text_12"
        app:layout_constraintBottom_toBottomOf="@id/aui_tv_train_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/aui_tv_train_name" />
</androidx.constraintlayout.widget.ConstraintLayout>

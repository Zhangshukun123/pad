<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <include
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_bar_high"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/app_title" />

    <include
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_title"
        layout="@layout/app_user_info" />

    <CheckBox
        android:id="@+id/aqsl_cb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_5"
        android:text="仅本人数据"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_user" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/aqsl_cb">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/dp_10"
            android:paddingTop="@dimen/dp_5"
            android:paddingEnd="@dimen/dp_10"
            android:paddingBottom="@dimen/dp_15">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/aqsg_tv_total_sale_money"
                        style="@style/sale_get_money_value"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/edittext_high"
                        android:layout_marginTop="@dimen/dp_10" />

                    <TextView
                        style="@style/text_ui"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/bg_white_round"
                        android:text="总销售收款额(元)" />
                </FrameLayout>

                <Space
                    android:layout_width="@dimen/dp_5"
                    android:layout_height="1dp" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/aqsg_tv_code_sale"
                        style="@style/sale_get_money_value"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/edittext_high"
                        android:layout_marginTop="@dimen/dp_10" />

                    <TextView
                        style="@style/text_ui"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/bg_white_round"
                        android:text="柜台销售额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/aqsg_tv_normal_sale_money"
                        style="@style/sale_get_money_value"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/edittext_high"
                        android:layout_marginTop="@dimen/dp_10" />

                    <TextView
                        style="@style/text_ui"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/bg_white_round"
                        android:text="正常销售额(元)" />
                </FrameLayout>

                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/aqsg_tv_online_sale_amount"
                        style="@style/sale_get_money_value"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/edittext_high"
                        android:layout_marginTop="@dimen/dp_10" />

                    <TextView
                        style="@style/text_ui"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/bg_white_round"
                        android:text="线上销售总额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_12306_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="12306销售额(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_cash_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="现金销售额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_cwzao_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="乘务早餐销售额(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_cwzheng_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="乘务正餐销售额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_alipay_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="支付宝销售额(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_wechat_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="微信销售额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/aqsg_tv_cash_get"
                        style="@style/sale_get_money_value"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/edittext_high"
                        android:layout_marginTop="@dimen/dp_10"
                        app:layout_constraintEnd_toStartOf="@id/aqsg_tv_cash_to_online"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/aqsg_tv_cash_to_online"
                        style="@style/sale_get_money_action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5"
                        android:text="转线上"
                        app:layout_constraintBottom_toBottomOf="@id/aqsg_tv_cash_get"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/aqsg_tv_cash_get"
                        app:layout_constraintTop_toTopOf="@id/aqsg_tv_cash_get" />

                    <TextView
                        style="@style/text_ui"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_white_round"
                        android:text="现金收款(元)"
                        app:layout_constraintEnd_toEndOf="@id/aqsg_tv_cash_get"
                        app:layout_constraintStart_toStartOf="@id/aqsg_tv_cash_get"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_scrapped" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="报废(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsl_tv_cash_to_alipay" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="现金转支付宝(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsl_tv_lost" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="丢失(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView android:id="@+id/aqsl_tv_cash_to_wechat" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="现金转微信(元)" />
                </FrameLayout>

                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/aqsl_tv_scrapped_lost_to_online"
                        style="@style/sale_get_money_value"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/edittext_high"
                        android:layout_marginTop="@dimen/dp_10"
                        app:layout_constraintEnd_toStartOf="@id/aqsg_tv_lost_scrapped_to_online"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/aqsg_tv_lost_scrapped_to_online"
                        style="@style/sale_get_money_action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5"
                        android:text="转线上"
                        app:layout_constraintBottom_toBottomOf="@id/aqsl_tv_scrapped_lost_to_online"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/aqsl_tv_scrapped_lost_to_online"
                        app:layout_constraintTop_toTopOf="@id/aqsl_tv_scrapped_lost_to_online" />

                    <TextView
                        style="@style/text_ui"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_white_round"
                        android:text="报废丢失转线上(元)"
                        app:layout_constraintEnd_toEndOf="@id/aqsl_tv_scrapped_lost_to_online"
                        app:layout_constraintStart_toStartOf="@id/aqsl_tv_scrapped_lost_to_online"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_tuancan_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="团餐销售额(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_vip_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="VIP销售额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_jiedai_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="接待销售额(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_waiju_sale_money" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="外局销售额(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsl_tv_alipay_get" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="支付宝收款(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_wechat_get" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="微信收款(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsl_tv_chengwuc" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="乘务餐(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsl_tv_work" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="工作餐(元)" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cl_23"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:orientation="horizontal"
                android:visibility="invisible">
                <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <TextView android:id="@+id/aqsg_tv_discount_amount" style="@style/sale_get_money_value" android:layout_width="match_parent" android:layout_height="@dimen/edittext_high" android:layout_marginTop="@dimen/dp_10" />
                    <TextView style="@style/text_ui" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:background="@drawable/bg_white_round" android:text="优惠金额(元)" />
                </FrameLayout>
                <Space android:layout_width="@dimen/dp_5" android:layout_height="1dp" />
                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
            </LinearLayout>

            <Button
                android:id="@+id/aqsg_btn_query_unusual_order"
                style="@style/button_long"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_long_high"
                android:layout_marginStart="@dimen/dp_24"
                android:layout_marginTop="@dimen/dp_15"
                android:layout_marginEnd="@dimen/dp_24"
                android:text="异常订单查询"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

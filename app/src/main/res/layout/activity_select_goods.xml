<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/white">

    <include
        android:layout_width="fill_parent"
        android:layout_height="@dimen/title_bar_high"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/app_title" />

    <include
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_title"
        layout="@layout/app_user_info" />

    <com.ayma.base.widget.ClearEditText
        android:id="@+id/asg_et_search_condition"
        style="@style/edittext_1"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/spinner_high"
        android:layout_margin="@dimen/dp_5"
        android:hint="@string/select_goods_search_hint"
        android:maxLines="1"
        android:paddingLeft="@dimen/dp_5"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_user" />

    <LinearLayout
        android:id="@+id/asg_ll_content"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/dp_5"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/sga_cl_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/asg_et_search_condition">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/asg_rlv_type"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@color/lightgray"
            android:paddingRight="@dimen/dp_1"
            android:scrollbars="none"
            android:layout_weight="0.95" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_weight="2.95">

            <TextView
                android:id="@+id/sga_tv_current_type"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@color/lightgray"
                android:paddingStart="@dimen/dp_10"
                android:paddingTop="@dimen/dp_10"
                android:paddingEnd="@dimen/dp_10"
                android:paddingBottom="@dimen/dp_10"
                android:textColor="@color/black"
                android:textSize="@dimen/text_16"
                android:textStyle="bold" />

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/sga_srl"
                android:layout_width="fill_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <FrameLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/sga_rlv_goods"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:clipToPadding="false"
                        android:paddingBottom="@dimen/dp_10"
                        android:scrollbars="vertical" />

                    <TextView
                        android:id="@+id/sga_tv_empty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/select_goods_empty_list"
                        android:textColor="@color/explain_text_color_2"
                        android:textSize="@dimen/text_14"
                        android:visibility="gone" />
                </FrameLayout>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sga_cl_bottom"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_white_top_black_line"
        android:padding="@dimen/dp_5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/sga_iv_shop_car"
            android:layout_width="@dimen/dp_35"
            android:layout_height="@dimen/dp_35"
            android:contentDescription="@string/select_goods_cart_title"
            android:padding="@dimen/dp_2"
            android:src="@mipmap/ic_shopcar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/sga_tv_goods_count"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_5"
            android:textColor="@color/sgf_goods_item_price_text"
            android:textSize="@dimen/text_14"
            app:layout_constraintBottom_toBottomOf="@id/sga_tv_total_label"
            app:layout_constraintEnd_toStartOf="@id/sga_tv_total_label"
            app:layout_constraintStart_toEndOf="@id/sga_iv_shop_car"
            app:layout_constraintTop_toTopOf="@id/sga_tv_total_label" />

        <TextView
            android:id="@+id/sga_tv_total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_5"
            android:text="@string/select_goods_total_label"
            android:textColor="@color/black"
            android:textSize="@dimen/text_16"
            app:layout_constraintBottom_toBottomOf="@id/sga_btn_submit"
            app:layout_constraintEnd_toStartOf="@id/sga_tv_goods_total_price"
            app:layout_constraintTop_toTopOf="@id/sga_btn_submit" />

        <TextView
            android:id="@+id/sga_tv_goods_total_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_10"
            android:textColor="@color/sgf_goods_item_price_text"
            android:textSize="@dimen/text_16"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/sga_btn_submit"
            app:layout_constraintEnd_toStartOf="@id/sga_btn_submit"
            app:layout_constraintTop_toTopOf="@id/sga_btn_submit" />

        <Button
            android:id="@+id/sga_btn_submit"
            android:layout_width="@dimen/dp_80"
            android:layout_height="@dimen/dp_50"
            android:background="@drawable/bg_dark_red_solid"
            android:text="@string/sell_action_submit"
            android:textColor="@color/white"
            android:textSize="@dimen/text_16"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

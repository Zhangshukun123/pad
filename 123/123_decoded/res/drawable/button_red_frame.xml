<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/ripple_color"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle" android:useLevel="true">
                    <stroke android:width="@dimen/dp_1" android:color="@color/menu_button_border" />
                    <solid android:color="#ffdddddd" />
                    <corners android:radius="@dimen/widget_round_radius" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle" android:useLevel="true">
                    <stroke android:width="@dimen/dp_1" android:color="@color/menu_button_border" />
                    <solid android:color="#ffffffff" />
                    <corners android:radius="@dimen/widget_round_radius" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
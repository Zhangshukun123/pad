<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/ripple_color"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle" android:useLevel="true">
                    <solid android:color="@color/widget_enable_false" />
                    <corners android:radius="@dimen/widget_round_radius" />
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape android:shape="rectangle" android:useLevel="true">
                    <solid android:color="@color/button_style_color_blue_dark" />
                    <corners android:radius="@dimen/widget_round_radius" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle" android:useLevel="true">
                    <solid android:color="@color/button_style_color_blue" />
                    <corners android:radius="@dimen/widget_round_radius" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>